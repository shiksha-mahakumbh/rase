# Shiksha Mahakumbh — environment template (copy to .env.local / hosting dashboard)
# Never commit real secrets. Verify: npm run verify:env

# --- Required: site ---
NEXT_PUBLIC_SITE_URL=https://www.rase.co.in

# --- Required: registration security (production) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# --- Required: payments (production) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# --- Required: email delivery ---
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@shikshamahakumbh.org
SMTP_PORT=587
REGISTRATION_EMAIL_SECRET=
REGISTRATION_EMAIL_REQUIRE_SECRET=false
ADMIN_OPS_SECRET=

# --- Required: Firebase Admin SDK (server registration, webhooks, email status) ---
# Paste full service account JSON as a single line (Vercel / hosting env)
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Optional: Firebase client (inline config used if unset) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=

# --- Optional: admin ---
NEXT_PUBLIC_ADMIN_EMAILS=

# --- Optional: analytics ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# --- Optional: ads ---
NEXT_PUBLIC_ADSENSE_ENABLED=
NEXT_PUBLIC_ADS_SLOTS_PREVIEW=

# --- Optional: monitoring ---
NEXT_PUBLIC_SENTRY_DSN=
VISITOR_COUNTER_USE_FIRESTORE=true
