# Shiksha Mahakumbh — environment template (copy to .env.local / Vercel)
# Never commit real secrets. Verify: npm run verify:env

# --- Required: canonical site ---
NEXT_PUBLIC_SITE_URL=https://www.shikshamahakumbh.com

# --- Required: Supabase Postgres (Prisma) ---
# Runtime: pooled URL (port 6543) with pgbouncer=true&connection_limit=1
# Build: set DIRECT_URL (port 5432) — used automatically during `next build` to avoid pool timeouts
# Optional overrides: PRISMA_CONNECTION_LIMIT, PRISMA_POOL_TIMEOUT
# Migrations: DIRECT_URL (port 5432, non-pooled)
DATABASE_URL=
DIRECT_URL=
# Optional — runtime uses Supabase regardless; set for env checks.
REGISTRATION_BACKEND=supabase

# --- Required: Supabase client ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Required: registration security (production) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.3
# Comma-separated hostnames returned by Google siteverify (optional)
# RECAPTCHA_ALLOWED_HOSTNAMES=www.shikshamahakumbh.com,shikshamahakumbh.com,www.rase.co.in,rase.co.in
REGISTRATION_LOOKUP_SECRET=
NEWSLETTER_TOKEN_SECRET=
REGISTRATION_UPLOAD_SECRET=
# Use distinct random values for each — do not reuse REGISTRATION_EMAIL_SECRET
ADMIN_OPS_SECRET=
ADMIN_SESSION_SECRET=
ADMIN_GATEWAY_SIGNING_SECRET=

# --- Required: payments (production) ---
# Whitelist ALL checkout domains in Razorpay Dashboard → Account & Settings → Website:
# www.shikshamahakumbh.com, shikshamahakumbh.com, www.rase.co.in, rase.co.in
# "Business - Website Mismatch" means the browser origin is not whitelisted.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# --- Required: email delivery (SMTP or Brevo SMTP relay) ---
# If BREVO_SMTP_HOST + BREVO_SMTP_USER + BREVO_SMTP_PASS are all set, Brevo is used.
# Otherwise SMTP_* variables are used.
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
# Alias supported: SMTP_PASSWORD
SMTP_FROM=noreply@shikshamahakumbh.com
SMTP_PORT=587
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_SMTP_FROM=
REGISTRATION_EMAIL_SECRET=
REGISTRATION_EMAIL_REQUIRE_SECRET=false

# --- Cron (Vercel scheduled jobs) ---
# Bearer token for /api/cron/* — Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- Optional: distributed rate limiting (Upstash Redis REST) ---
# When set, public and admin routes use shared counters across serverless instances.
# Vercel Upstash integration sets KV_REST_API_URL + KV_REST_API_TOKEN automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Optional: admin (server-only bootstrap) ---
ADMIN_BOOTSTRAP_EMAILS=

# --- Optional: analytics ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# --- Optional: ads ---
NEXT_PUBLIC_ADSENSE_ENABLED=
NEXT_PUBLIC_ADS_SLOTS_PREVIEW=

# --- Optional: monitoring ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Optional: visitor counter baseline ---
# Firestore visitors/total.count at Supabase cutover (default 80433 → ~1.75L with legacy 94567)
# VISITOR_FIRESTORE_BASELINE=80433
