# Supabase backend — environment template

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── PostgreSQL (Prisma) ─────────────────────────────────────────────────────
# Pooled connection (Supavisor) for serverless — port 6543, user postgres.[ref]
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection for migrations — host db.[ref].supabase.co, port 5432, user postgres
DIRECT_URL=postgresql://postgres:[password]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── Backend mode ────────────────────────────────────────────────────────────
# Runtime is Supabase-only; set for env checks / documentation.
REGISTRATION_BACKEND=supabase

# ─── Brevo SMTP ──────────────────────────────────────────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-login
BREVO_SMTP_PASS=your-brevo-smtp-key
BREVO_SMTP_FROM=noreply@shikshamahakumbh.org

# ─── Payments & security (see .env.example) ─────────────────────────────────
# RAZORPAY_KEY_ID=...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
# RECAPTCHA_SECRET_KEY=...
# ADMIN_OPS_SECRET=...
