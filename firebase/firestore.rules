rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid))
        && get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.role in [
          'admin', 'superadmin', 'coordinator', 'reviewer',
          'Super Admin', 'Admin', 'Data Entry'
        ];
    }

    match /adminUsers/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /registrations/{docId} {
      allow create: if false;
      allow read, update, delete: if isAdminUser();
    }

    match /registrationCounters/{docId} {
      allow read, write: if false;
    }

    match /paymentRecords/{docId} {
      allow read: if isAdminUser();
      allow create, update, delete: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAdminUser();
      allow create, update, delete: if false;
    }

    match /accommodationRequests/{docId} {
      allow read: if isAdminUser();
      allow create, update, delete: if false;
    }

    match /{collection}/{docId} {
      allow read: if isAdminUser();
      allow create, update, delete: if false;
    }
  }
}
