rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid))
        && get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'coordinator', 'reviewer', 'Super Admin', 'Admin', 'Data Entry'];
    }

    function validRegistrationCreate() {
      return request.resource.data.keys().hasAll(['registrationId', 'registrationType', 'email', 'fullName'])
        && request.resource.data.registrationId is string
        && request.resource.data.registrationId.matches('SMK2026-[0-9]{6}')
        && request.resource.data.email is string
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() >= 2;
    }

    match /adminUsers/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /registrations/{docId} {
      allow create: if validRegistrationCreate();
      allow read, update, delete: if isAdminUser();
    }

    match /registrationCounters/{docId} {
      allow read: if isAdminUser();
      allow write: if false;
    }

    match /audit_logs/{logId} {
      allow create: if request.resource.data.keys().hasAll(['action'])
        && request.resource.data.action is string;
      allow read, update, delete: if isAdminUser();
    }

    match /{collection}/{docId} {
      allow read, write: if isAdminUser();
    }
  }
}
