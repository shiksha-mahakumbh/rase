rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null;
    }

    match /registrations/{type}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches(
          'application/pdf|image/jpeg|image/jpg|image/png|image/webp|text/csv|application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
        );
    }

    match /{allPaths=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
