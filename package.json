{
  "name": "rase",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node scripts/run-next.js dev",
    "dev:turbo": "node scripts/run-next.js dev --turbo",
    "dev:clean": "node scripts/clean-next-cache.js --kill-node && node scripts/run-next.js dev",
    "postinstall": "prisma generate",
    "build": "node scripts/build-production.js",
