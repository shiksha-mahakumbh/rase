    "build:clean": "node scripts/clean-next-cache.js --kill-node && node scripts/build-production.js",
    "typecheck": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "type-check": "npm run typecheck",
    "start": "node scripts/run-next.js start",
    "lint": "next lint",
    "smoke:prod": "node scripts/production-smoke-test.mjs",
    "backup:drill": "node scripts/backup-restore-drill.mjs",
    "validate:go-live": "node scripts/validate-go-live.mjs",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "lighthouse:local": "node scripts/run-lighthouse.mjs",
    "validate:p3c": "node scripts/p3c-staging-validation.mjs",
    "verify:env": "node scripts/verify-env.mjs",
    "setup:vercel:audit": "node scripts/setup-audit-vercel-env.mjs",
