    "export:gcp-storage": "node scripts/gcp-export-storage.mjs",
    "gcp:shutdown": "node scripts/gcp-shutdown-project.mjs",
    "audit:go-live": "node scripts/launch-go-live-audit.mjs",
    "audit:production": "node scripts/production-registration-audit.mjs",
    "audit:past-editions": "tsx scripts/audit-past-editions.ts",
    "audit:past-editions-performance": "tsx scripts/audit-past-editions-performance.ts",
    "audit:site-performance": "tsx scripts/audit-site-performance.ts",
    "compress:edition-gallery": "node scripts/compress-edition-gallery-images.mjs",
    "browserslist:update": "npx browserslist@latest --update-db",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:validate": "prisma validate",
    "db:seed": "node scripts/supabase/seed-rbac.mjs",
    "db:deploy-supabase": "node scripts/deploy-supabase-production.mjs",
    "test:security": "node scripts/staging-security-check.mjs && node scripts/firebase-removal-audit.mjs && node scripts/test-registration-lookup-security.mjs && node scripts/test-registration-types.mjs && node scripts/test-v2-registration-security.mjs",
    "test:visitor-analytics": "node scripts/test-visitor-analytics-race.mjs",
    "test": "npm run test:security && npm run test:visitor-analytics",
    "seed:cms": "node scripts/seed-cms-content.mjs",
    "seed:press": "node scripts/seed-press-cms.mjs --publish",
    "seed:press:draft": "node scripts/seed-press-cms.mjs",
    "extract:abhiyan-images": "node scripts/pdf-extract-tmp/extract.mjs && node scripts/pdf-extract-tmp/render-pages.cjs && node scripts/pdf-extract-tmp/crop-portraits.cjs"
  },
  "prisma": {
    "seed": "node scripts/supabase/seed-rbac.mjs"
  },
  "browserslist": [
    "chrome >= 92",
    "edge >= 92",
    "firefox >= 90",
    "safari >= 15.4"
  ],
  "dependencies": {
