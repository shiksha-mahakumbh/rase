    "next": "15.5.19",
    "next-intl": "^3.26.0",
    "next-qrcode": "^2.5.1",
    "nodemailer": "^7.0.12",
    "puppeteer-core": "^24.43.1",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-fast-marquee": "^1.6.2",
    "react-hook-form": "^7.77.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.1",
    "react-intersection-observer": "^9.10.3",
    "react-organizational-chart": "^2.2.1",
    "react-responsive-carousel": "^3.2.23",
    "react-share": "^5.1.1",
    "react-slick": "^0.30.2",
    "react-transition-group": "^4.4.5",
    "recharts": "^3.8.1",
    "slick-carousel": "^1.8.1",
    "ts-node": "^10.9.2",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-slick": "^0.23.13",
    "@types/react-transition-group": "^4.4.10",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "caniuse-lite": "^1.0.30001793",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "playwright": "^1.60.0",
    "postcss": "^8.4.47",
    "prisma": "^6.19.3",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.7.2"
  }
