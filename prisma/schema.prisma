// ─── Auth & RBAC ─────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(uuid()) @db.Uuid
  authUserId  String?   @unique @map("auth_user_id") @db.Uuid // Supabase auth.users.id
  email       String    @unique
  fullName    String?   @map("full_name")
  avatarUrl   String?   @map("avatar_url")
  phone       String?
  isActive    Boolean   @default(true) @map("is_active")
  sessionVersion Int    @default(0) @map("session_version")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp String?   @map("last_login_ip")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  userRoles       UserRole[]
  auditLogs       AuditLog[]       @relation("AuditActor")
  emailLogs       EmailLog[]
  uploadedFiles   UploadedFile[]   @relation("UploadedBy")
  contactReplies  ContactMessage[] @relation("ContactReplier")
  feedbackReplies Feedback[]       @relation("FeedbackReplier")

  @@index([email])
  @@index([authUserId])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique // Super Admin, Admin, Data Entry, Coordinator, etc.
  slug        String    @unique
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  resource    String // registrations, committees, media, settings, users
  action      String // read, create, update, delete, export, manage
  slug        String   @unique // registrations.read, committees.manage
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── System ───────────────────────────────────────────────────────────────────

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     Json
  category  String   @default("general")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_settings")
}

model RegistrationCounter {
  id         String   @id @default(uuid()) @db.Uuid
  year       Int      @default(2026)
  prefix     String   @default("SMK2026")
  lastNumber Int      @default(0) @map("last_number")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([prefix])
  @@unique([year])
  @@map("registration_counters")
}

// ─── Core Registration Engine ─────────────────────────────────────────────────

model Registration {
  id                  String               @id @default(uuid()) @db.Uuid
  registrationId      String               @unique @map("registration_id") // SMK2026-000001
  registrationType    RegistrationType     @map("registration_type")
  registrationStatus  RegistrationStatus   @default(Submitted) @map("registration_status")
  paymentStatus       PaymentStatus        @default(Not_Required) @map("payment_status")
  accommodationStatus AccommodationStatus  @default(Not_Required) @map("accommodation_status")
  emailDeliveryStatus EmailDeliveryStatus? @map("email_delivery_status")

  // Receipt & QR tracking
  receiptGeneratedAt  DateTime? @map("receipt_generated_at") @db.Timestamptz(6)
  receiptSentAt       DateTime? @map("receipt_sent_at") @db.Timestamptz(6)
  receiptDownloadedAt DateTime? @map("receipt_downloaded_at") @db.Timestamptz(6)
  qrGeneratedAt       DateTime? @map("qr_generated_at") @db.Timestamptz(6)
  qrStoragePath       String?   @map("qr_storage_path")
  qrSentAt            DateTime? @map("qr_sent_at") @db.Timestamptz(6)

  // Lifecycle — check-in, kit, certificate eligibility
  state                      String?
  checkInStatus              CheckInStatus              @default(Not_Checked_In) @map("check_in_status")
  checkedInAt                DateTime?                  @map("checked_in_at") @db.Timestamptz(6)
  checkedInByUserId          String?                    @map("checked_in_by_user_id") @db.Uuid
  checkInLocation            String?                    @map("check_in_location")
  kitDistributed             Boolean                    @default(false) @map("kit_distributed")
  kitDistributedAt           DateTime?                  @map("kit_distributed_at") @db.Timestamptz(6)
  certificateEligible        Boolean                    @default(false) @map("certificate_eligible")
  certificateLifecycleStatus CertificateLifecycleStatus @default(Not_Applicable) @map("certificate_lifecycle_status")

  // Common participant fields
  fullName       String            @map("full_name")
  gender         Gender
  designation    String
  institution    String
  address        String
  country        String            @default("India")
  email          String
  contactNumber  String            @map("contact_number")
  whatsappNumber String?           @map("whatsapp_number")
  vidyaBharti    VidyaBhartiStatus @map("vidya_bharti")

  // Accommodation
  accommodationRequired YesNo   @default(No) @map("accommodation_required")
  accommodationDate     String? @map("accommodation_date")
  accommodationType     String? @map("accommodation_type")
  participantCategory   String? @map("participant_category")

  // Payment snapshot
  registrationFee   Decimal? @map("registration_fee") @db.Decimal(12, 2)
  utrNumber         String?  @map("utr_number")
  transactionId     String?  @map("transaction_id")
  razorpayOrderId   String?  @map("razorpay_order_id")
  razorpayPaymentId String?  @map("razorpay_payment_id")

  // Flexible payload for type-specific fields not yet normalized
  metadata Json @default("{}")

  // Original Firestore document IDs for migrated rows (column names unchanged)
  legacyMasterDocId String? @map("firebase_master_doc_id")
  legacyTypeDocId   String? @map("firebase_type_doc_id")
  source            String  @default("supabase") // supabase | migration

  submittedIp String? @map("submitted_ip")
  userAgent   String? @map("user_agent")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  statusHistory           RegistrationStatusHistory[]
  uploadedFiles           UploadedFile[]
  paymentRecords          PaymentRecord[]
  accommodationRequest    AccommodationRequest?
  emailLogs               EmailLog[]
  auditLogs               AuditLog[]
  checkInRecords          CheckInRecord[]
  attendeeCertificate     AttendeeCertificate?
  attendeeBadge           AttendeeBadge?
  sessionAttendances      SessionAttendance[]
  researchSubmissions     ResearchSubmission[]
  communicationRecipients CommunicationRecipient[]
  volunteerAssignment     VolunteerAssignment?
  speakerOperations       SpeakerOperations?
  alumniRecord            AlumniRecord?
  whatsAppMessageLogs     WhatsAppMessageLog[]
  generatedDocuments      GeneratedDocument[]

  conclaveRegistration     ConclaveRegistration?
  delegateRegistration     DelegateRegistration?
  exhibitionRegistration   ExhibitionRegistration?
  awardsRegistration       AwardsRegistration?
  bestPracticeRegistration BestPracticeRegistration?
  olympiadRegistration     OlympiadRegistration?
  talentRegistration       TalentRegistration?
  volunteerApplication     VolunteerApplication?
  ngoRegistration          NgoRegistration?
  participantRegistration  ParticipantRegistration?

  @@index([registrationType])
  @@index([registrationStatus])
  @@index([paymentStatus])
  @@index([checkInStatus])
  @@index([state])
  @@index([institution])
  @@index([email])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("registrations")
}

model RegistrationStatusHistory {
  id              String              @id @default(uuid()) @db.Uuid
  registrationId  String              @map("registration_id") @db.Uuid
  fromStatus      RegistrationStatus? @map("from_status")
  toStatus        RegistrationStatus  @map("to_status")
  changedByUserId String?             @map("changed_by_user_id") @db.Uuid
  reason          String?
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId, createdAt])
  @@map("registration_status_history")
}

