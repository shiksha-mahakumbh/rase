  osVersion      String?    @map("os_version")
  screenWidth    Int?       @map("screen_width")
  screenHeight   Int?       @map("screen_height")

  session VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([deviceType])
  @@map("visitor_devices")
}

model VisitorLocation {
  id          String  @id @default(uuid()) @db.Uuid
  sessionId   String  @unique @map("session_id") @db.Uuid
  country     String?
  countryCode String? @map("country_code")
  state       String?
  city        String?

  session VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([countryCode])
  @@index([country, state])
  @@map("visitor_locations")
}

model TrafficSource {
  id             String  @id @default(uuid()) @db.Uuid
  sessionId      String  @unique @map("session_id") @db.Uuid
  source         String?
  medium         String?
  campaign       String?
  term           String?
  content        String?
  referrerDomain String? @map("referrer_domain")

  session VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([source, medium])
  @@map("traffic_sources")
}

