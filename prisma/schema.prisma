// Shiksha Mahakumbh 2026 — Supabase PostgreSQL schema
// Generator: Prisma · Runtime: Next.js Route Handlers + Server Actions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

