// ─── Phase S2: Media Albums ───────────────────────────────────────────────────

model MediaAlbum {
  id           String        @id @default(uuid()) @db.Uuid
  title        String
  slug         String
  description  String?       @db.Text
  albumType    AlbumType     @default(gallery) @map("album_type")
  locale       ContentLocale @default(en)
  edition      String?
  year         Int?
  coverAssetId String?       @map("cover_asset_id") @db.Uuid
  status       PageStatus    @default(draft)
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)

  items MediaAlbumItem[]

  @@unique([slug, locale])
  @@index([albumType, status])
  @@map("media_albums")
}

model MediaAlbumItem {
  id           String   @id @default(uuid()) @db.Uuid
  albumId      String   @map("album_id") @db.Uuid
  mediaAssetId String?  @map("media_asset_id") @db.Uuid
  imageUrl     String?  @map("image_url")
  caption      String?
  altText      String?  @map("alt_text")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  album      MediaAlbum  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([albumId, sortOrder])
  @@index([mediaAssetId])
  @@map("media_album_items")
}

model AnnouncementBar {
  id            String              @id @default(uuid()) @db.Uuid
  title         String
  message       String              @db.Text
  barType       AnnouncementBarType @default(global) @map("bar_type")
  colorTheme    String              @default("primary") @map("color_theme")
  ctaLabel      String?             @map("cta_label")
  ctaUrl        String?             @map("cta_url")
  locale        ContentLocale       @default(en)
  isDismissible Boolean             @default(true) @map("is_dismissible")
  isActive      Boolean             @default(true) @map("is_active")
  priority      Int                 @default(0)
  startsAt      DateTime?           @map("starts_at") @db.Timestamptz(6)
  endsAt        DateTime?           @map("ends_at") @db.Timestamptz(6)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?           @map("deleted_at") @db.Timestamptz(6)

  @@index([isActive, startsAt, endsAt])
  @@index([barType, locale])
  @@map("announcement_bars")
}

// ─── Phase 4: AI Operations & Automation ─────────────────────────────────────

model EventSession {
  id               String           @id @default(uuid()) @db.Uuid
  slug             String           @unique
  title            String
  sessionType      EventSessionType @default(other) @map("session_type")
  description      String?          @db.Text
  venue            String?
  capacity         Int              @default(100)
  startAt          DateTime         @map("start_at") @db.Timestamptz(6)
  endAt            DateTime         @map("end_at") @db.Timestamptz(6)
  speakerName      String?          @map("speaker_name")
  speakerProfileId String?          @map("speaker_profile_id") @db.Uuid
  qrToken          String?          @unique @map("qr_token")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(6)

  attendances       SessionAttendance[]
  speakerOperations SpeakerOperations[]

  @@index([startAt])
  @@index([sessionType, isActive])
  @@map("event_sessions")
}

model VolunteerAssignment {
  id              String    @id @default(uuid()) @db.Uuid
  registrationId  String    @unique @map("registration_id") @db.Uuid
  department      String
  shiftStart      DateTime? @map("shift_start") @db.Timestamptz(6)
  shiftEnd        DateTime? @map("shift_end") @db.Timestamptz(6)
  supervisorName  String?   @map("supervisor_name")
  supervisorPhone String?   @map("supervisor_phone")
  attendedAt      DateTime? @map("attended_at") @db.Timestamptz(6)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([department])
  @@map("volunteer_assignments")
}

model SpeakerOperations {
  id                  String           @id @default(uuid()) @db.Uuid
  registrationId      String?          @unique @map("registration_id") @db.Uuid
  speakerProfileId    String?          @map("speaker_profile_id") @db.Uuid
  eventSessionId      String?          @map("event_session_id") @db.Uuid
  travelStatus        String?          @map("travel_status")
  accommodationStatus String?          @map("accommodation_status")
  honorariumStatus    HonorariumStatus @default(not_applicable) @map("honorarium_status")
  honorariumAmount    Decimal?         @map("honorarium_amount") @db.Decimal(12, 2)
  scheduleNotes       String?          @map("schedule_notes") @db.Text
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  eventSession EventSession? @relation(fields: [eventSessionId], references: [id], onDelete: SetNull)

  @@index([honorariumStatus])
  @@index([eventSessionId])
  @@map("speaker_operations")
}

model AlumniRecord {
  id                   String   @id @default(uuid()) @db.Uuid
  registrationId       String   @unique @map("registration_id") @db.Uuid
  eventEdition         String   @default("SMK2026") @map("event_edition")
  fullName             String   @map("full_name")
  email                String
  institution          String?
  state                String?
  interests            String[] @default([])
  researchAreas        String[] @default([]) @map("research_areas")
  participationHistory Json     @default("[]") @map("participation_history")
  convertedAt          DateTime @default(now()) @map("converted_at") @db.Timestamptz(6)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([eventEdition])
  @@index([state])
  @@index([institution])
  @@map("alumni_records")
}

model WorkflowRule {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  trigger         WorkflowTrigger
  channel         WorkflowChannel @default(email)
  isEnabled       Boolean         @default(true) @map("is_enabled")
  templateSubject String?         @map("template_subject")
  templateBody    String?         @map("template_body") @db.Text
  config          Json            @default("{}")
  sortOrder       Int             @default(0) @map("sort_order")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([trigger, name])
  @@index([trigger, isEnabled])
  @@map("workflow_rules")
}

model AiInsightSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  generatedAt     DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)
  insights        Json     @default("[]")
  recommendations Json     @default("[]")
  metrics         Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([generatedAt])
  @@map("ai_insight_snapshots")
}

model WhatsAppMessageLog {
  id                String                @id @default(uuid()) @db.Uuid
  registrationId    String?               @map("registration_id") @db.Uuid
  phone             String
  template          String
  body              String                @db.Text
  status            WhatsAppMessageStatus @default(queued)
  providerMessageId String?               @map("provider_message_id")
  errorMessage      String?               @map("error_message")
  sentAt            DateTime?             @map("sent_at") @db.Timestamptz(6)
  deliveredAt       DateTime?             @map("delivered_at") @db.Timestamptz(6)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  @@index([registrationId])
  @@index([status])
  @@index([phone])
  @@map("whatsapp_message_logs")
}

model GeneratedDocument {
  id             String             @id @default(uuid()) @db.Uuid
  documentType   DocumentLetterType @map("document_type")
  registrationId String?            @map("registration_id") @db.Uuid
  title          String
  recipientName  String?            @map("recipient_name")
  storagePath    String?            @map("storage_path")
  bulkBatchId    String?            @map("bulk_batch_id")
  metadata       Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  @@index([documentType])
  @@index([bulkBatchId])
  @@index([registrationId])
  @@map("generated_documents")
}
