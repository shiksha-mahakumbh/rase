// ─── Phase 3.5: Media Library ─────────────────────────────────────────────────

model MediaFolder {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String
  parentId  String?   @map("parent_id") @db.Uuid
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  parent   MediaFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children MediaFolder[] @relation("FolderTree")
  assets   MediaAsset[]

  @@unique([slug, parentId])
  @@map("media_folders")
}

model MediaAsset {
  id           String         @id @default(uuid()) @db.Uuid
  folderId     String?        @map("folder_id") @db.Uuid
  fileName     String         @map("file_name")
  originalName String         @map("original_name")
  storagePath  String         @map("storage_path")
  publicUrl    String?        @map("public_url") @db.Text
  mimeType     String         @map("mime_type")
  assetType    MediaAssetType @default(other) @map("asset_type")
  sizeBytes    Int            @map("size_bytes")
  altText      String?        @map("alt_text")
  tags         String[]       @default([])
  usageCount   Int            @default(0) @map("usage_count")
  version      Int            @default(1)
  isCurrent    Boolean        @default(true) @map("is_current")
  replacedById String?        @map("replaced_by_id") @db.Uuid
  uploadedById String?        @map("uploaded_by_id") @db.Uuid
  metadata     Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(6)

  folder            MediaFolder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  replacedBy        MediaAsset?        @relation("AssetReplacement", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces          MediaAsset[]       @relation("AssetReplacement")
  downloads         Download[]
  noticeAttachments NoticeAttachment[]
  albumItems        MediaAlbumItem[]
  committeeMembers  CommitteeMember[]
  speakerProfiles   SpeakerProfile[]
  partners          Partner[]
  eventMediaItems   EventMedia[]

  @@index([folderId])
  @@index([tags])
  @@index([assetType, isCurrent])
  @@index([replacedById])
  @@map("media_assets")
}

