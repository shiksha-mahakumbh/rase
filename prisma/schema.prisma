// ─── Analytics — Phase B.5 Visitor Intelligence ─────────────────────────────

model VisitorAnalytics {
  id             String   @id @default(uuid()) @db.Uuid
  date           DateTime @db.Date
  dailyCount     Int      @default(0) @map("daily_count")
  totalCount     Int      @default(0) @map("total_count")
  uniqueCount    Int      @default(0) @map("unique_count")
  returningCount Int      @default(0) @map("returning_count")
  botFiltered    Int      @default(0) @map("bot_filtered")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([date])
  @@map("visitor_analytics")
}

model VisitorSession {
  id            String    @id @default(uuid()) @db.Uuid
  sessionId     String    @unique @map("session_id")
  visitorId     String    @map("visitor_id")
  isReturning   Boolean   @default(false) @map("is_returning")
  isBot         Boolean   @default(false) @map("is_bot")
  ipHash        String?   @map("ip_hash")
  userAgent     String?   @map("user_agent") @db.Text
  referrer      String?   @db.Text
  landingPath   String    @map("landing_path")
  lastPath      String?   @map("last_path")
  pageViewCount Int       @default(1) @map("page_view_count")
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  lastActiveAt  DateTime  @default(now()) @map("last_active_at") @db.Timestamptz(6)
  endedAt       DateTime? @map("ended_at") @db.Timestamptz(6)

  device        VisitorDevice?
  location      VisitorLocation?
  trafficSource TrafficSource?
  pageViews     VisitorPageView[]
  events        VisitorEvent[]

  @@index([visitorId])
  @@index([startedAt])
  @@index([lastActiveAt])
  @@index([isBot, startedAt])
  @@map("visitor_sessions")
}

model VisitorPageView {
  id           String       @id @default(uuid()) @db.Uuid
  sessionId    String       @map("session_id") @db.Uuid
  path         String
  pageCategory PageCategory @default(other) @map("page_category")
  title        String?
  referrer     String?      @db.Text
  utmSource    String?      @map("utm_source")
  utmMedium    String?      @map("utm_medium")
  utmCampaign  String?      @map("utm_campaign")
  utmTerm      String?      @map("utm_term")
  utmContent   String?      @map("utm_content")
  durationMs   Int?         @map("duration_ms")
  viewedAt     DateTime     @default(now()) @map("viewed_at") @db.Timestamptz(6)

  session VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([path])
  @@index([pageCategory, viewedAt])
  @@index([viewedAt])
  @@index([sessionId])
  @@map("visitor_page_views")
}

model VisitorEvent {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  eventType  String   @map("event_type")
  eventName  String   @map("event_name")
  path       String?
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json     @default("{}")
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  session VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([eventType, occurredAt])
  @@index([entityType, entityId])
  @@index([sessionId])
  @@map("visitor_events")
}

model VisitorDevice {
  id             String     @id @default(uuid()) @db.Uuid
  sessionId      String     @unique @map("session_id") @db.Uuid
  deviceType     DeviceType @default(unknown) @map("device_type")
  browser        String?
  browserVersion String?    @map("browser_version")
