model AccommodationRequest {
  id                       String              @id @default(uuid()) @db.Uuid
  registrationId           String              @unique @map("registration_id") @db.Uuid
  status                   AccommodationStatus @default(Requested)
  notes                    String?             @db.Text
  bedType                  String?             @map("bed_type")
  building                 String?
  roomNumber               String?             @map("room_number")
  bedNumber                String?             @map("bed_number")
  roomId                   String?             @map("room_id") @db.Uuid
  checkInDate              DateTime?           @map("check_in_date") @db.Date
  checkOutDate             DateTime?           @map("check_out_date") @db.Date
